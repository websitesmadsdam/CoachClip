NODE_ENV=development
PORT=3000

MAX_CONCURRENT_EXPORTS=2
FFMPEG_TIMEOUT_SECONDS=600
OUTPUT_TTL_MINUTES=60
LOG_LEVEL=info

CORS_ORIGIN=http://localhost:3000

RATE_LIMIT_EXPORT_CREATE=5
RATE_LIMIT_EXPORT_CREATE_WINDOW_SECONDS=600
RATE_LIMIT_STATUS=180
RATE_LIMIT_STATUS_WINDOW_SECONDS=60
RATE_LIMIT_DOWNLOAD=20
RATE_LIMIT_DOWNLOAD_WINDOW_SECONDS=3600

SHUTDOWN_GRACE_PERIOD_SECONDS=30
