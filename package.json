{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:export:simple": "tsx scripts/smokeExportSimple.ts",
    "smoke:export:no-audio": "tsx scripts/smokeExportNoAudio.ts",
    "smoke:api:simple": "tsx scripts/smokeApiSimple.ts",
    "smoke:export": "tsx scripts/smokeExportCombined.ts",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run smoke:export:simple && npm run smoke:export:no-audio && npm run smoke:export && npm run smoke:api:simple"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "express": "^5.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "eslint": "^9.20.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.0",
    "typescript": "~5.8.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
